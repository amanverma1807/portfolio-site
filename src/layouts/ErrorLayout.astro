---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  statusCode: string;
  title: string;
  description: string;
}

const { statusCode, title, description } = Astro.props;
---

<Layout title={`${statusCode} | Aman Verma`}>
  <Header />
  <main>
    <section class="error-hero tile-bg-black">
      <div class="error-content reveal">
        <span class="error-code">{statusCode}</span>
        <h1 class="display-lg">{title}</h1>
        <p class="lead">{description}</p>
        <div class="error-actions">
          <a href="/" class="btn-primary btn-press">Go Home</a>
          <a href="#contact" class="btn-secondary btn-press">Contact Support</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .error-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--spacing-section) var(--spacing-lg);
  }

  .error-content {
    max-width: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .error-code {
    font-family: var(--font-display);
    font-size: 120px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text-muted);
    opacity: 0.3;
  }

  .error-content h1 {
    color: var(--color-text);
  }

  .error-content p {
    color: var(--color-text-muted);
    max-width: 480px;
  }

  .error-actions {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-md);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    background-color: var(--color-primary);
    color: var(--color-bg-black);
    font-size: 17px;
    font-weight: 600;
    border-radius: var(--rounded-pill);
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 28px;
    background-color: transparent;
    color: var(--color-primary);
    font-size: 17px;
    font-weight: 600;
    border: 1px solid var(--color-primary);
    border-radius: var(--rounded-pill);
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .btn-secondary:hover {
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .error-code {
      font-size: 80px;
    }

    .error-actions {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }

    .btn-primary,
    .btn-secondary {
      width: 100%;
    }
  }
</style>
