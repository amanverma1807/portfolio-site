---
---

<section id="skills" class="skills-section tile-bg-black">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="section-label">Competencies</span>
      <h2 class="display-lg section-title">Core Skills</h2>
      <p class="body-copy section-subtitle">
        My technical competencies across development, programming, tools, and optimization, built through hands-on practice.
      </p>
    </div>

    <div class="skills-grid reveal reveal-delay-2">
      <!-- Skill Group 1: Frontend -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
        </div>
        <h3 class="tagline skill-title">Frontend</h3>
        <p class="body-copy skill-desc">
          Building clean, interactive interfaces using modern web standards and layout principles.
        </p>
        <div class="skills-chips">
          <span class="skill-chip">HTML5</span>
          <span class="skill-chip">CSS3</span>
          <span class="skill-chip">JavaScript (ES6+)</span>
          <span class="skill-chip">Astro</span>
          <span class="skill-chip">Responsive Design</span>
        </div>
      </div>

      <!-- Skill Group 2: Programming -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
        </div>
        <h3 class="tagline skill-title">Programming</h3>
        <p class="body-copy skill-desc">
          Writing clean, readable code and building backend automation scripts in Python.
        </p>
        <div class="skills-chips">
          <span class="skill-chip">Python</span>
        </div>
      </div>

      <!-- Skill Group 3: Tools -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"></line><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9a9 9 0 0 1-9 9"></path></svg>
        </div>
        <h3 class="tagline skill-title">Tools</h3>
        <p class="body-copy skill-desc">
          Managing version control and developing in modern integrated environments.
        </p>
        <div class="skills-chips">
          <span class="skill-chip">Git</span>
          <span class="skill-chip">GitHub</span>
          <span class="skill-chip">VS Code</span>
        </div>
      </div>

      <!-- Skill Group 4: Other -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>
        </div>
        <h3 class="tagline skill-title">Other</h3>
        <p class="body-copy skill-desc">
          Optimizing search visibility, loading speeds, and visual design layouts.
        </p>
        <div class="skills-chips">
          <span class="skill-chip">SEO</span>
          <span class="skill-chip">Performance Optimization</span>
          <span class="skill-chip">UI/UX Basics</span>
          <span class="skill-chip">Problem Solving</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: var(--spacing-xxl);
    max-width: 600px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: var(--spacing-xs);
  }

  .section-title {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-muted);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-lg);
  }

  .skill-card {
    background-color: var(--color-bg-tile-1);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: border-color 0.3s ease, transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .skill-card:hover {
    border-color: rgba(255, 255, 255, 0.16);
    transform: translateY(-4px);
  }

  .card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--rounded-sm);
    background-color: rgba(255, 255, 255, 0.03);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-md);
    border: 1px solid var(--color-border);
  }

  .skill-title {
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
  }

  .skill-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
    line-height: 1.5;
    flex: 1;
  }

  .skills-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .skill-chip {
    background-color: rgba(255, 255, 255, 0.04);
    color: var(--color-text-muted);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: var(--rounded-md); /* 11px radius standard for secondary chips */
    border: 1px solid var(--color-border);
  }

  /* Responsive styling */
  @media (max-width: 1068px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>
