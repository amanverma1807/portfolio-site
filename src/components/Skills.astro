---
---

<section id="skills" class="skills-section tile-bg-black">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="section-label">Competencies</span>
      <h2 class="display-lg section-title">Core Skills</h2>
      <p class="body-copy section-subtitle">
        My technical competencies span multiple areas, focusing on high-performance backend pipelines and responsive frontends.
      </p>
    </div>

    <div class="skills-grid reveal reveal-delay-2">
      <!-- Skill Group 1: Backend Systems -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
        </div>
        <h3 class="tagline skill-title">Backend Architecture</h3>
        <p class="body-copy skill-desc">
          Building resilient API gateways, managing asynchronous worker queues, and designing normalized databases.
        </p>
        <div class="skill-chips">
          <span class="skill-chip">REST APIs</span>
          <span class="skill-chip">gRPC</span>
          <span class="skill-chip">PostgreSQL</span>
          <span class="skill-chip">Redis Cache</span>
          <span class="skill-chip">RabbitMQ</span>
        </div>
      </div>

      <!-- Skill Group 2: Systems & Automation -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
        </div>
        <h3 class="tagline skill-title">Python & Automation</h3>
        <p class="body-copy skill-desc">
          Creating robust ETL scripts, web scrapers, task automation daemons, and data engineering pipelines.
        </p>
        <div class="skill-chips">
          <span class="skill-chip">Python asyncio</span>
          <span class="skill-chip">Playwright</span>
          <span class="skill-chip">Pandas</span>
          <span class="skill-chip">ETL pipelines</span>
          <span class="skill-chip">Shell scripting</span>
        </div>
      </div>

      <!-- Skill Group 3: Frontend Craftsmanship -->
      <div class="skill-card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        </div>
        <h3 class="tagline skill-title">Frontend Engineering</h3>
        <p class="body-copy skill-desc">
          Crafting semantic responsive templates, optimizing page speeds, and implementing layout interfaces.
        </p>
        <div class="skill-chips">
          <span class="skill-chip">Astro Islands</span>
          <span class="skill-chip">React</span>
          <span class="skill-chip">TypeScript</span>
          <span class="skill-chip">Vanilla CSS</span>
          <span class="skill-chip">Fluid Grids</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: var(--spacing-xxl);
    max-width: 600px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: var(--spacing-xs);
  }

  .section-title {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-muted);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .skill-card {
    background-color: var(--color-bg-tile-1);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: border-color 0.3s ease, transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .skill-card:hover {
    border-color: rgba(255, 255, 255, 0.16);
    transform: translateY(-4px);
  }

  .card-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--rounded-sm);
    background-color: rgba(255, 255, 255, 0.03);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing-md);
    border: 1px solid var(--color-border);
  }

  .skill-title {
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
  }

  .skill-desc {
    font-size: 14px;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
    line-height: 1.5;
    flex: 1;
  }

  .skills-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .skill-chip {
    background-color: rgba(255, 255, 255, 0.04);
    color: var(--color-text-muted);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: var(--rounded-md); /* 11px radius standard for secondary chips */
    border: 1px solid var(--color-border);
  }

  /* Responsive styling */
  @media (max-width: 834px) {
    .skills-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>
