<style>
  .global-footer {
    position: relative;
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-xxl) 0;
  }

  .footer-container {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .footer-disclaimer {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
  }

  .disclaimer-text {
    color: var(--color-text-muted-dark);
    line-height: 1.5;
  }

  .footer-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--spacing-md) 0;
  }

  /* Link stacks */
  .footer-directory {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .directory-title {
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  .directory-list {
    list-style: none;
    padding: 0;
  }

  .footer-link {
    font-size: 13px;
    font-weight: 400;
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: 2.41; /* Apple's relaxed link spacing standard */
    display: inline-block;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  /* Bottom Row */
  .footer-legal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    padding-top: var(--spacing-xs);
  }

  .legal-text {
    color: var(--color-text-muted-dark);
  }

  .legal-links {
    list-style: none;
    display: flex;
    gap: var(--spacing-md);
    padding: 0;
  }

  .legal-link {
    color: var(--color-text-muted-dark);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .legal-link:hover {
    color: var(--color-text-muted);
  }

  /* Responsive layout collapse */
  @media (max-width: 640px) {
    .footer-directory {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
    
    .footer-legal {
      flex-direction: column;
      align-items: flex-start;
    }
    
    .legal-links {
      flex-wrap: wrap;
      gap: var(--spacing-sm);
    }
  }
</style>
