---
---

<section id="tech" class="tech-section tile-bg-3">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="section-label">Inventory</span>
      <h2 class="display-lg section-title">Tech Stack</h2>
      <p class="body-copy section-subtitle">
        Technologies and tools used to build, optimize, and deploy this portfolio website.
      </p>
    </div>

    <div class="tech-grid reveal reveal-delay-2">
      <!-- Tech Item 1: Astro -->
      <div class="tech-card">
        <div class="tech-icon astro-color">
          <span>As</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Astro</h3>
          <p class="caption tech-desc">The primary framework used to build this high-performance portfolio website.</p>
        </div>
      </div>

      <!-- Tech Item 2: Tailwind CSS -->
      <div class="tech-card">
        <div class="tech-icon tailwind-color">
          <span>Tw</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Tailwind CSS</h3>
          <p class="caption tech-desc">Utility-first CSS framework used for responsive layouts and modern styling.</p>
        </div>
      </div>

      <!-- Tech Item 3: TypeScript -->
      <div class="tech-card">
        <div class="tech-icon ts-color">
          <span>Ts</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">TypeScript</h3>
          <p class="caption tech-desc">Provides type safety and improves code maintainability throughout the project.</p>
        </div>
      </div>

      <!-- Tech Item 4: Vite -->
      <div class="tech-card">
        <div class="tech-icon vite-color">
          <span>Vt</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Vite</h3>
          <p class="caption tech-desc">Fast development server and optimized production build tool.</p>
        </div>
      </div>

      <!-- Tech Item 5: Cloudflare Pages -->
      <div class="tech-card">
        <div class="tech-icon cf-pages-color">
          <span>Cp</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Cloudflare Pages</h3>
          <p class="caption tech-desc">Hosting platform used to deploy and serve the portfolio globally.</p>
        </div>
      </div>

      <!-- Tech Item 6: Cloudflare Adapter -->
      <div class="tech-card">
        <div class="tech-icon cf-adapter-color">
          <span>Ca</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Cloudflare Adapter</h3>
          <p class="caption tech-desc">Enables Astro server-side features on Cloudflare's infrastructure.</p>
        </div>
      </div>

      <!-- Tech Item 7: Wrangler -->
      <div class="tech-card">
        <div class="tech-icon wrangler-color">
          <span>Wr</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Wrangler</h3>
          <p class="caption tech-desc">Cloudflare CLI used for local development and deployment.</p>
        </div>
      </div>

      <!-- Tech Item 8: Astro Sitemap -->
      <div class="tech-card">
        <div class="tech-icon sitemap-color">
          <span>Sm</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Astro Sitemap</h3>
          <p class="caption tech-desc">Automatically generates sitemap.xml to improve SEO and search engine indexing.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tech-section {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: var(--spacing-xxl);
    max-width: 600px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: var(--spacing-xs);
  }

  .section-title {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-muted);
  }

  /* Grid mimicking Apple's accessories page layout */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
  }

  .tech-card {
    background-color: var(--color-bg-tile-1);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  .tech-card:hover {
    background-color: var(--color-bg-tile-2);
    border-color: rgba(255, 255, 255, 0.12);
  }

  /* Tech icon monogram styling */
  .tech-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--rounded-sm);
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
    font-family: var(--font-display);
    flex-shrink: 0;
  }

  /* Distinct soft tint border/color to make it look extremely premium */
  .astro-color { color: #ff9500; border-color: rgba(255, 149, 0, 0.2); }
  .tailwind-color { color: #38bdf8; border-color: rgba(56, 189, 248, 0.2); }
  .ts-color { color: #2997ff; border-color: rgba(41, 151, 255, 0.2); }
  .vite-color { color: #bf5af2; border-color: rgba(191, 90, 242, 0.2); }
  .cf-pages-color { color: #ff9f0a; border-color: rgba(255, 159, 10, 0.2); }
  .cf-adapter-color { color: #5e5ce6; border-color: rgba(94, 92, 230, 0.2); }
  .wrangler-color { color: #30d158; border-color: rgba(48, 209, 88, 0.2); }
  .sitemap-color { color: #64d2ff; border-color: rgba(100, 210, 255, 0.2); }

  .tech-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tech-name {
    color: var(--color-text);
  }

  .tech-desc {
    color: var(--color-text-muted);
    font-size: 12px;
    line-height: 1.3;
  }

  /* Responsive breakpoints */
  @media (max-width: 1068px) {
    .tech-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 834px) {
    .tech-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
