---
---

<section id="tech" class="tech-section tile-bg-3">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="section-label">Inventory</span>
      <h2 class="display-lg section-title">Tech Stack</h2>
      <p class="body-copy section-subtitle">
        A directory of frameworks, languages, and tools I use to build scalable products.
      </p>
    </div>

    <div class="tech-grid reveal reveal-delay-2">
      <!-- Tech Item 1: Python -->
      <div class="tech-card">
        <div class="tech-icon py-color">
          <span>Py</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Python</h3>
          <p class="caption tech-desc">Asynchronous pipelines, scraping, APIs.</p>
        </div>
      </div>

      <!-- Tech Item 2: TypeScript -->
      <div class="tech-card">
        <div class="tech-icon ts-color">
          <span>TS</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">TypeScript</h3>
          <p class="caption tech-desc">Robust backend logic and dynamic interfaces.</p>
        </div>
      </div>

      <!-- Tech Item 3: Astro -->
      <div class="tech-card">
        <div class="tech-icon astro-color">
          <span>As</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Astro</h3>
          <p class="caption tech-desc">Static pages, content collections, fast load.</p>
        </div>
      </div>

      <!-- Tech Item 4: React -->
      <div class="tech-card">
        <div class="tech-icon react-color">
          <span>Re</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">React</h3>
          <p class="caption tech-desc">Client islands, state managers, dashboard views.</p>
        </div>
      </div>

      <!-- Tech Item 5: PostgreSQL -->
      <div class="tech-card">
        <div class="tech-icon pg-color">
          <span>Pg</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">PostgreSQL</h3>
          <p class="caption tech-desc">Primary relational data repository.</p>
        </div>
      </div>

      <!-- Tech Item 6: Redis -->
      <div class="tech-card">
        <div class="tech-icon redis-color">
          <span>Rd</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Redis</h3>
          <p class="caption tech-desc">In-memory caching tiers and task queues.</p>
        </div>
      </div>

      <!-- Tech Item 7: Docker -->
      <div class="tech-card">
        <div class="tech-icon docker-color">
          <span>Dk</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Docker</h3>
          <p class="caption tech-desc">Virtual container networks and deployment scripts.</p>
        </div>
      </div>

      <!-- Tech Item 8: Git & CI/CD -->
      <div class="tech-card">
        <div class="tech-icon git-color">
          <span>Gt</span>
        </div>
        <div class="tech-details">
          <h3 class="body-strong tech-name">Git & Deploy</h3>
          <p class="caption tech-desc">GitHub workflows and build pipelines.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tech-section {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: var(--spacing-xxl);
    max-width: 600px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: var(--spacing-xs);
  }

  .section-title {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-muted);
  }

  /* Grid mimicking Apple's accessories page layout */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);
  }

  .tech-card {
    background-color: var(--color-bg-tile-1);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  .tech-card:hover {
    background-color: var(--color-bg-tile-2);
    border-color: rgba(255, 255, 255, 0.12);
  }

  /* Tech icon monogram styling */
  .tech-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--rounded-sm);
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
    font-family: var(--font-display);
    flex-shrink: 0;
  }

  /* Distinct soft tint border/color to make it look extremely premium */
  .py-color { color: #30d158; border-color: rgba(48, 209, 88, 0.2); }
  .ts-color { color: #2997ff; border-color: rgba(41, 151, 255, 0.2); }
  .astro-color { color: #ff9500; border-color: rgba(255, 149, 0, 0.2); }
  .react-color { color: #5ac8fa; border-color: rgba(90, 200, 250, 0.2); }
  .pg-color { color: #bf5af2; border-color: rgba(191, 90, 242, 0.2); }
  .redis-color { color: #ff453a; border-color: rgba(255, 69, 58, 0.2); }
  .docker-color { color: #64d2ff; border-color: rgba(100, 210, 255, 0.2); }
  .git-color { color: #acafb8; border-color: rgba(172, 175, 184, 0.2); }

  .tech-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tech-name {
    color: var(--color-text);
  }

  .tech-desc {
    color: var(--color-text-muted);
    font-size: 12px;
    line-height: 1.3;
  }

  /* Responsive breakpoints */
  @media (max-width: 1068px) {
    .tech-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 834px) {
    .tech-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
