---
interface Props {
  title: string;
  description: string;
  githubUrl?: string;
}

const { title, description, githubUrl } = Astro.props;
---

<div class="python-project-card reveal">
  <div class="card-header">
    <span class="python-badge">Python</span>
  </div>
  
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
  </div>
  
  <div class="card-footer">
    {githubUrl && (
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="github-link btn-press">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
        <span>GitHub</span>
      </a>
    )}
  </div>
</div>

<style>
  .python-project-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    overflow: hidden;
    height: 100%;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.3s ease, box-shadow 0.4s ease;
  }

  .python-project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: rgba(0, 0, 0, 0.4) 0px 12px 28px -4px;
  }

  .card-header {
    padding: var(--spacing-md) var(--spacing-lg) 0;
  }

  .python-badge {
    display: inline-block;
    background: linear-gradient(135deg, #3776ab 0%, #30a2e8 100%);
    color: #ffffff;
    font-size: 10px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--rounded-pill);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 0 2px 8px rgba(55, 118, 171, 0.3);
  }

  .card-content {
    padding: var(--spacing-sm) var(--spacing-lg) var(--spacing-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: var(--spacing-xs);
  }

  .card-description {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .card-footer {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
    border-top: 1px solid var(--color-border);
    background-color: rgba(255, 255, 255, 0.01);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    padding: 8px 12px;
    border-radius: var(--rounded-md);
    border: 1px solid var(--color-border);
    background-color: rgba(255, 255, 255, 0.02);
    transition: all 0.2s ease;
  }

  .github-link:hover {
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.2);
    background-color: rgba(255, 255, 255, 0.05);
    transform: translateY(-1px);
  }

  .github-link svg {
    transition: transform 0.2s ease;
  }

  .github-link:hover svg {
    transform: translateX(2px);
  }

  .btn-press:active {
    transform: scale(0.97);
  }
</style>