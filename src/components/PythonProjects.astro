---
import PythonProjectCard from './PythonProjectCard.astro';
---

<section id="python-projects" class="python-projects-section tile-bg-2">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="section-label">Backend & Automation</span>
      <h2 class="display-lg section-title">Python Projects</h2>
      <p class="body-copy section-subtitle">
        Script utilities, data analysis tools, and automation scripts engineered with Python for real-world problem solving.
      </p>
    </div>

    <div class="projects-grid">
      <div class="grid-item reveal reveal-delay-1">
        <PythonProjectCard
          title="Invoice Generator"
          description="Generates professional invoices automatically using Python with customizable templates and export options."
          githubUrl="https://github.com/amanverma1807/Invoice-generator"
        />
      </div>
      
      <div class="grid-item reveal reveal-delay-2">
        <PythonProjectCard
          title="Student Grade Finder"
          description="Calculates student grades based on marks and grading criteria with detailed reporting and analytics."
          githubUrl="https://github.com/amanverma1807/student-result-calculator"
        />
      </div>
      
      <div class="grid-item reveal reveal-delay-3">
        <PythonProjectCard
          title="Phone Sales Analyzer"
          description="Analyzes phone sales data and provides useful sales insights with visualizations and trend detection."
          githubUrl="https://github.com/amanverma1807/Phone-sales-analyzer"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .python-projects-section {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: var(--spacing-xxl);
    max-width: 600px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: var(--spacing-xs);
  }

  .section-title {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
  }

  @media (max-width: 1068px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-sm);
    }
  }
</style>