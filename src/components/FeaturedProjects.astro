---
import ProjectCard from './ProjectCard.astro';
import gymforgeHome from '../assets/gymforge-home.png';
import attendancecalcHome from '../assets/attendancecalc-home.png';
---

<section id="projects" class="projects-section tile-bg-black">
  <div class="section-container">
    <div class="section-header reveal">
      <span class="section-label">Featured Work</span>
      <h2 class="display-lg section-title">Featured Web Projects</h2>
      <p class="body-copy section-subtitle">
        High-performance web applications built with modern frontend frameworks, optimized for speed and accessibility.
      </p>
    </div>

    <div class="projects-grid">
      <div class="grid-item reveal reveal-delay-1">
        <ProjectCard
          title="Gym Toolkit"
          description="An all-in-one fitness web application that provides multiple gym-related tools to help users calculate, track, and improve their fitness journey."
          tags={['Astro', 'JavaScript', 'HTML', 'CSS']}
          demoUrl="https://gymforge.online"
          githubUrl="https://github.com/amanverma1807/gymforge"
          screenshot={gymforgeHome.src}
        />
      </div>
      
      <div class="grid-item reveal reveal-delay-2">
        <ProjectCard
          title="Attendance Calculator"
          description="A web application that helps students calculate attendance percentage and determine how many classes they need to attend or can safely miss."
          tags={['Astro', 'JavaScript', 'HTML', 'CSS']}
          demoUrl="https://attendancecalc.online"
          githubUrl="https://github.com/amanverma1807/Attendance-calculator"
          screenshot={attendancecalcHome.src}
        />
      </div>
    </div>
  </div>
</section>

<style>
  .projects-section {
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    margin-bottom: var(--spacing-xxl);
    max-width: 600px;
  }

  .section-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: inline-block;
    margin-bottom: var(--spacing-xs);
  }

  .section-title {
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .section-subtitle {
    color: var(--color-text-muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  @media (max-width: 834px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>