---
interface Props {
  title: string;
  description: string;
  tags: string[];
  demoUrl?: string;
  githubUrl?: string;
  screenshot?: string;
}

const {
  title,
  description,
  tags,
  demoUrl,
  githubUrl,
  screenshot
} = Astro.props;
---

<div class="project-card reveal">
  {screenshot && (
    <div class="card-screenshot">
      {demoUrl ? (
        <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="screenshot-link">
          <img
            src={screenshot}
            alt={`${title} screenshot`}
            loading="lazy"
          />
        </a>
      ) : (
        <img
          src={screenshot}
          alt={`${title} screenshot`}
          loading="lazy"
        />
      )}
    </div>
  )}

  <div class="card-details">
    <h3 class="card-title display-md">{title}</h3>
    <p class="card-description body-copy">{description}</p>

    <div class="tag-badges">
      {tags.map((tag) => <span class="tag-badge">{tag}</span>)}
    </div>

    <div class="card-actions">
      {demoUrl && (
        <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="action-link demo-link btn-press">
          <span>Live Demo</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
      )}
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="action-link github-link btn-press">
          <span>Source Code</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--rounded-lg);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.3s ease, box-shadow 0.4s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.16);
    box-shadow: rgba(0, 0, 0, 0.6) 0px 12px 30px -5px;
  }

  .card-screenshot {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: #0b0b0c;
  }

  .screenshot-link {
    display: block;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .card-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--color-border);
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .screenshot-link:hover .card-screenshot img,
  .card-screenshot:hover img {
    transform: scale(1.03);
  }

  .card-details {
    padding: var(--spacing-md) var(--spacing-lg) var(--spacing-lg);
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 20px !important;
    line-height: 1.25;
    margin-bottom: 6px;
    color: var(--color-text);
  }

  .card-description {
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.45;
    margin-bottom: var(--spacing-sm);
  }

  .tag-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: var(--spacing-md);
  }

  .tag-badge {
    background-color: rgba(255, 255, 255, 0.06);
    color: var(--color-text-muted);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: var(--rounded-pill);
    border: 1px solid var(--color-border);
    letter-spacing: -0.01em;
  }

  .card-actions {
    display: flex;
    gap: var(--spacing-md);
  }

  .action-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-primary);
  }

  .action-link svg {
    transition: transform 0.2s ease;
  }

  .action-link:hover {
    color: var(--color-primary-hover);
  }

  .action-link:hover svg {
    transform: translate(1px, -1px);
  }

  .github-link {
    color: var(--color-text-muted);
  }

  .github-link:hover {
    color: var(--color-text);
  }

  .github-link:hover svg {
    transform: scale(1.1);
  }
</style>
